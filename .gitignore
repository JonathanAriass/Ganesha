# Dependencies
node_modules/

# Build output
dist/
dist-electron/
out/
# build/ is also the electron-builder buildResources dir (icon sources live there).
# Exclude generated package artifacts but track the icon source assets.
build/**
!build/icon.svg
!build/icon.png
!build/entitlements.mac.plist
release/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets
.env
.env.local
.env.*.local

# OS cruft
.DS_Store
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/

# Brainstorming visual companion (local only)
.superpowers/

# Local app data / databases that should never be committed
*.sqlite
*.sqlite3
*.db

# LLM spike artifacts (throwaway)
.spike-models/
